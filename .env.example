# ─────────────────────────────────────────────────────────────────────────────
# Best Coatings Solutions — environment variables (EXAMPLE)
#
# Copy to `.env.local` for local development. NEVER commit real secrets.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
#
# Phase 6: production-launch readiness seams are listed below. Live delivery
# stays off until SUBMISSION_DELIVERY_ENABLED=true and required credentials exist.
# Portal / Supabase / Stripe remain deferred (see FUTURE.md).
# ─────────────────────────────────────────────────────────────────────────────

# Public site origin (used for canonical URLs, OG tags, sitemap, robots).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Form delivery gate ──────────────────────────────────────────────────────
# Keep false until Resend + Turnstile + rate-limit credentials are configured
# and owner/legal blockers are cleared.
SUBMISSION_DELIVERY_ENABLED=false

# ── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=
BCS_SUBMISSION_TO_EMAIL=info@bestcoatingssolutions.com
BCS_SUBMISSION_FROM_EMAIL=Best Coatings Solutions <onboarding@resend.dev>

# ── Cloudflare Turnstile (bot protection) ───────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Upstash Redis (rate limiting) ───────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
BCS_RATE_LIMIT_WINDOW_MS=60000
BCS_RATE_LIMIT_MAX=8

# ── Sentry (error monitoring — no full PII payloads) ────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Vercel Blob (estimate photo uploads — optional at launch) ───────────────
BLOB_READ_WRITE_TOKEN=

# ── Analytics ───────────────────────────────────────────────────────────────
# Vercel Analytics needs no key when deployed on Vercel.

# ── Deferred (do not enable for Phase 6 launch) ─────────────────────────────
# Supabase (auth + PostgreSQL) — portal/ops deferred
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (customer portal payments) — deferred
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Maps / Reviews — deferred
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# Scheduling — deferred
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# SMS — deferred
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
