# ─────────────────────────────────────────────────────────────────────────────
# Best Coatings Solutions — environment variables (EXAMPLE)
#
# Copy to `.env.local` for local development. NEVER commit real secrets.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Everything below is placeholder/architecture only — integrations are not yet
# implemented (see ROADMAP.md).
# ─────────────────────────────────────────────────────────────────────────────

# Public site origin (used for canonical URLs, OG tags, sitemap, robots).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (auth + PostgreSQL) ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (customer portal payments) ───────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Maps / Reviews ──────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# ── Scheduling ──────────────────────────────────────────────────────────────
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ── Notifications (email / SMS) ─────────────────────────────────────────────
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Analytics ───────────────────────────────────────────────────────────────
# Vercel Analytics needs no key when deployed on Vercel.
